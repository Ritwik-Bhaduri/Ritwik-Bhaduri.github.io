        stroke-linecap="round"
        stroke-linejoin="round"
        d="M4 6h16v12H4V6zm0 0 8 7 8-7"
      />
    </svg>
  ) : name === "publications" ? (
    <svg class={cls} viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path
        fill="none"
        stroke="currentColor"
        stroke-width="1.65"
        stroke-linejoin="round"
        d="M6 4h9a2 2 0 0 1 2 2v14l-5-3-5 3V4zM9 8h6M9 11h6"
      />
    </svg>
  ) : name === "projects" ? (
