      <path
        fill="none"
        stroke="currentColor"
        stroke-width="1.65"
        stroke-linejoin="round"
        d="M4 8h3l2-2h6l2 2h3v11H4V8zm8 3a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"
      />
    </svg>
  ) : name === "cv" ? (
    <svg class={cls} viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path
        fill="none"
        stroke="currentColor"
        stroke-width="1.65"
        stroke-linejoin="round"
        d="M8 4h8l4 4v12a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zm0 8h8M8 12h8M8 16h5"
      />
    </svg>
  ) : name === "download" ? (
    <svg class={cls} viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path
        fill="none"
        stroke="currentColor"
        stroke-width="1.65"
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M12 4v10m0 0 4-4m-4 4-4-4M6 18h12"
      />
    </svg>
  ) : name === "contact" ? (
    <svg class={cls} viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path
        fill="none"
        stroke="currentColor"
        stroke-width="1.65"
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M8 10h.01M12 10h.01M16 10h.01M8 20l4-4 4 4M6 16H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2"
