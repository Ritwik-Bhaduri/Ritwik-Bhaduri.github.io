---
import type { HomeProfileIcon } from "../data/homeProfileLinks";

interface Props {
  name: HomeProfileIcon;
  class?: string;
}

const { name, class: className } = Astro.props;
const cls = ["profile-icon-svg", className].filter(Boolean).join(" ");
