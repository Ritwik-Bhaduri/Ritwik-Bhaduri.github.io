      <path
        fill="none"
        stroke="currentColor"
        stroke-width="1.65"
        stroke-linejoin="round"
        d="M4 7h5l2-2h6l2 2h3v12H4V7z"
      />
      <path fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" d="M12 11v4" />
    </svg>
  ) : name === "experience" ? (
    <svg class={cls} viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path
        fill="none"
        stroke="currentColor"
        stroke-width="1.65"
        stroke-linejoin="round"
        d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M6 7h12v11a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V7zm4 4h4"
      />
