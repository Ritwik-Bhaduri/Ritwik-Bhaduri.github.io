---
import fs from "node:fs";
import path from "node:path";
import MainLayout from "../layouts/MainLayout.astro";
import PageIntro from "../components/PageIntro.astro";

const IMG_RE = /\.(jpg|jpeg|png|gif|webp|avif)$/i;
const photoBase = path.join(process.cwd(), "public/images/photography");

interface AlbumMeta { description?: string; order?: number; }

const albums = fs
  .readdirSync(photoBase, { withFileTypes: true })
  .filter((e) => e.isDirectory())
  .map((dir) => {
    const folder = dir.name;
    const title = folder.replace(/_/g, " ");

    let meta: AlbumMeta = {};
    const metaPath = path.join(photoBase, folder, "_meta.json");
    if (fs.existsSync(metaPath)) {
      try { meta = JSON.parse(fs.readFileSync(metaPath, "utf-8")); } catch {}
    }

    const images = fs
      .readdirSync(path.join(photoBase, folder))
      .filter((f) => IMG_RE.test(f))
      .sort()
      .map((f) => {
        const thumbName = f.replace(/\.[^.]+$/, ".webp");
        return {
          src: `/images/photography/${folder}/${f}`,
          thumb: `/images/photography/${folder}/_thumb/${thumbName}`,
        };
      });

    return { title, description: meta.description ?? "", order: meta.order ?? 999, images };
  })
  .filter((a) => a.images.length > 0)
  .sort((a, b) => a.order - b.order);

const galleryData = albums.map((a) => ({
  title: a.title,
  images: a.images.map((i) => i.src),
}));
---

<MainLayout
  title="Ritwik Bhaduri | Photography"
  description="Selected travel photography in short series."
>
  <PageIntro
    title="Welcome to my photography collection!"
    intro="When I'm not working I enjoy capturing places, moments, and details that stand out to me as I travel. 
    This gallery is a selection of photographs that reflect how I see the world, from landscapes and city scenes to everyday moments along the way."
  />

  <div class="container">
    <div class="gallery-page">
      {albums.map((series, si) => (
        <section class="gseries">
          <header class="gseries__hd">
            <span class="gseries__num" aria-hidden="true">{String(si + 1).padStart(2, "0")}</span>
            <div>
              <h2 class="gseries__title">{series.title}</h2>
              <p class="gseries__desc">{series.description}</p>
            </div>
          </header>

          <div class="gmasonry">
            {series.images.map((src: { src: string; thumb: string }, ii: number) => (
              <button
                class="gitem"
                type="button"
                data-si={si}
                data-ii={ii}
                aria-label={`View photo ${ii + 1} of ${series.images.length} — ${series.title}`}
              >
                <img
                  src={src.thumb}
                  alt=""
                  class="gitem__img"
                  loading={si === 0 && ii < 2 ? "eager" : "lazy"}
                  decoding="async"
                />
                <span class="gitem__overlay" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"
                       stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 3 21 3 21 9"/>
                    <polyline points="9 21 3 21 3 15"/>
                    <line x1="21" y1="3" x2="14" y2="10"/>
                    <line x1="3" y1="21" x2="10" y2="14"/>
                  </svg>
                </span>
              </button>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>

  <!-- Lightbox -->
  <div class="lb" id="lb" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
    <div class="lb__bg" id="lb-bg"></div>

    <button class="lb__close" id="lb-close" type="button" aria-label="Close photo viewer">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <button class="lb__arrow lb__arrow--l" id="lb-prev" type="button" aria-label="Previous photo">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>

    <div class="lb__stage">
      <img class="lb__img" id="lb-img" src="" alt="" />
    </div>

    <button class="lb__arrow lb__arrow--r" id="lb-next" type="button" aria-label="Next photo">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>

    <p class="lb__cap" id="lb-cap"></p>
  </div>
</MainLayout>

<style>
  /* ── Gallery page wrapper ───────────────────────────────────── */
  .gallery-page { padding-bottom: 2.5rem; }

  /* ── Series section ─────────────────────────────────────────── */
  .gseries { margin-bottom: 4rem; }
  .gseries:last-child { margin-bottom: 0; }

  .gseries__hd {
    display: flex;
    align-items: flex-start;
    gap: 1.1rem;
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .gseries__num {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--accent);
    text-transform: uppercase;
    padding-top: 0.42rem;
    flex-shrink: 0;
  }

  .gseries__title {
    margin: 0 0 0.35rem;
    font-size: clamp(1.05rem, 2.5vw, 1.38rem);
    font-weight: 650;
    letter-spacing: -0.025em;
    line-height: 1.2;
  }

  .gseries__desc {
    margin: 0;
    font-family: var(--font-ui);
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--muted);
    max-width: 54rem;
  }

  /* ── Masonry grid ───────────────────────────────────────────── */
  .gmasonry {
    columns: 3;
    column-gap: 0.65rem;
  }

  .gitem {
    break-inside: avoid;
    display: block;
    width: 100%;
    margin-bottom: 0.65rem;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    cursor: zoom-in;
    overflow: hidden;
    position: relative;
    /* scroll-reveal initial state */
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 520ms ease,
      transform 520ms ease,
      border-color 160ms ease;
  }

  .gitem--in {
    opacity: 1;
    transform: translateY(0);
  }

  .gitem:hover,
  .gitem:focus-visible {
    border-color: var(--accent);
    outline: none;
  }

  .gitem__img {
    width: 100%;
    display: block;
    transition: transform 500ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .gitem:hover .gitem__img {
    transform: scale(1.045);
  }

  /* expand icon */
  .gitem__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0);
    transition: background 260ms ease;
    pointer-events: none;
  }

  .gitem__overlay svg {
    width: 1.55rem;
    height: 1.55rem;
    color: #fff;
    opacity: 0;
    transform: scale(0.78);
    transition: opacity 260ms ease, transform 260ms ease;
    filter: drop-shadow(0 1px 4px rgba(0, 0, 0, 0.65));
  }

  .gitem:hover .gitem__overlay { background: rgba(0, 0, 0, 0.18); }
  .gitem:hover .gitem__overlay svg { opacity: 1; transform: scale(1); }

  /* ── Lightbox ───────────────────────────────────────────────── */
  .lb {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lb[hidden] { display: none; }

  .lb__bg {
    position: absolute;
    inset: 0;
    background: rgba(6, 8, 12, 0.93);
    cursor: zoom-out;
  }

  /* close button */
  .lb__close {
    position: absolute;
    top: 0.9rem;
    right: 1rem;
    z-index: 1;
    width: 2.4rem;
    height: 2.4rem;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.07);
    color: #fff;
    cursor: pointer;
    transition: background 150ms, border-color 150ms;
  }
  .lb__close svg { width: 0.9rem; height: 0.9rem; }
  .lb__close:hover { background: rgba(255, 255, 255, 0.16); border-color: rgba(255, 255, 255, 0.3); }

  /* prev / next arrows */
  .lb__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1;
    width: 3rem;
    height: 3rem;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.07);
    color: #fff;
    cursor: pointer;
    transition: background 150ms, border-color 150ms, opacity 150ms;
  }
  .lb__arrow:hover { background: rgba(255, 255, 255, 0.16); border-color: rgba(255, 255, 255, 0.3); }
  .lb__arrow:disabled { opacity: 0.2; pointer-events: none; }
  .lb__arrow--l { left: 1.25rem; }
  .lb__arrow--r { right: 1.25rem; }
  .lb__arrow svg { width: 1.2rem; height: 1.2rem; }

  /* image stage */
  .lb__stage {
    position: relative;
    z-index: 1;
    max-width: calc(100vw - 9rem);
    max-height: calc(100vh - 5rem);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lb__img {
    max-width: 100%;
    max-height: calc(100vh - 5rem);
    object-fit: contain;
    display: block;
    border-radius: 2px;
    transition: opacity 180ms ease;
  }

  .lb__img.lb--fade { opacity: 0; }

  /* caption */
  .lb__cap {
    position: absolute;
    bottom: 0.9rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    margin: 0;
    color: rgba(255, 255, 255, 0.42);
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    white-space: nowrap;
    pointer-events: none;
  }

  /* ── Responsive ─────────────────────────────────────────────── */
  @media (max-width: 820px) {
    .gmasonry { columns: 2; }
  }

  @media (max-width: 500px) {
    .gmasonry { columns: 1; }
    .gseries__hd { flex-direction: column; gap: 0.15rem; }
    .gseries__num { padding-top: 0; }
    .lb__stage { max-width: calc(100vw - 1rem); }
    .lb__arrow { width: 2.3rem; height: 2.3rem; }
    .lb__arrow--l { left: 0.3rem; }
    .lb__arrow--r { right: 0.3rem; }
  }
</style>

<script is:inline define:vars={{ galleryData }}>
(function () {
  var lb      = document.getElementById('lb');
  var lbImg   = document.getElementById('lb-img');
  var lbCap   = document.getElementById('lb-cap');
  var lbPrev  = document.getElementById('lb-prev');
  var lbNext  = document.getElementById('lb-next');
  var lbBg    = document.getElementById('lb-bg');
  var lbClose = document.getElementById('lb-close');
  if (!lb || !lbImg) return;

  var cur = { si: 0, ii: 0 };

  function setImage(si, ii, animate) {
    var s = galleryData[si];
    if (!s) return;
    cur.si = si;
    cur.ii = ii;
    lbCap.textContent = s.title + '  \u00b7  ' + (ii + 1) + ' / ' + s.images.length;
    lbPrev.disabled = (ii === 0);
    lbNext.disabled = (ii === s.images.length - 1);

    if (animate) {
      lbImg.classList.add('lb--fade');
      setTimeout(function () {
        lbImg.onload = function () {
          lbImg.classList.remove('lb--fade');
          lbImg.onload = null;
        };
        lbImg.src = s.images[ii];
        lbImg.alt = s.title;
      }, 160);
    } else {
      lbImg.src = s.images[ii];
      lbImg.alt = s.title;
    }
  }

  function openLb(si, ii) {
    setImage(si, ii, false);
    lb.hidden = false;
    document.body.style.overflow = 'hidden';
    lbClose.focus();
  }

  function closeLb() {
    lb.hidden = true;
    document.body.style.overflow = '';
  }

  // Thumbnails
  document.querySelectorAll('.gitem').forEach(function (btn) {
    btn.addEventListener('click', function () {
      openLb(Number(btn.dataset.si), Number(btn.dataset.ii));
    });
  });

  // Controls
  lbClose.addEventListener('click', closeLb);
  lbBg.addEventListener('click', closeLb);
  lbPrev.addEventListener('click', function () {
    if (cur.ii > 0) setImage(cur.si, cur.ii - 1, true);
  });
  lbNext.addEventListener('click', function () {
    var s = galleryData[cur.si];
    if (cur.ii < s.images.length - 1) setImage(cur.si, cur.ii + 1, true);
  });

  document.addEventListener('keydown', function (e) {
    if (lb.hidden) return;
    if (e.key === 'Escape')     { closeLb(); }
    if (e.key === 'ArrowLeft')  { lbPrev.click(); }
    if (e.key === 'ArrowRight') { lbNext.click(); }
  });

  // Scroll-reveal
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('gitem--in');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });

    document.querySelectorAll('.gitem').forEach(function (item, i) {
      item.style.transitionDelay = ((i % 3) * 70) + 'ms';
      io.observe(item);
    });
  } else {
    document.querySelectorAll('.gitem').forEach(function (item) {
      item.classList.add('gitem--in');
    });
  }
}());
</script>
